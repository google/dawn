# generate_embedded_hlsl_headers aggregates hlsl snippets generated by
# embed_hlsl_header into two .inc files, as is done in the official CMake build:
# tools/clang/lib/Lex/CMakeLists.txt Invokes the same python script as the CMake
# build.
template("generate_embedded_hlsl_headers") {
  assert(defined(invoker.inputs), "must set 'inputs'")
  assert(defined(invoker.target_dir), "must set 'target_dir'")
  assert(defined(invoker.decls_output), "must set 'decls_output'")
  assert(defined(invoker.entries_output), "must set 'entries_output'")

  action(target_name) {
    script = "${invoker.dawn_dxc_dir}/utils/generate_hlsl_embedded_headers.py"
    deps = invoker.deps
    sources = invoker.inputs
    outputs = [
      invoker.decls_output,
      invoker.entries_output,
    ]

    # Script wants "--entry <base_name1>=<input1> --entry <base_name2>=<input2>"
    entries = []
    foreach(input, invoker.inputs) {
      # Turn "<invoker.target_dir>/enable_if.h.inc"
      # into "enable_if.h"
      base_name = string_replace(input, invoker.target_dir + "/", "")
      base_name = string_replace(base_name, ".inc", "")

      entries += [ "--entry" ]

      # Rebase 'input' against 'target_dir' so that the two generated files
      # produce file-relative includes.
      entries += [ "$base_name=" + rebase_path(input, invoker.target_dir) ]
    }

    args = [
             "--decls-output",
             rebase_path(invoker.decls_output, root_build_dir),
             "--entries-output",
             rebase_path(invoker.entries_output, root_build_dir),
           ] + entries
  }
}
