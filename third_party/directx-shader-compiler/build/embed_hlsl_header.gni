# embed_hlsl_header is used to generate HLSL embedded headers
# as is done in the official CMake build: tools/clang/lib/Lex/CMakeLists.txt
# Invokes the same python script as the CMake build.
template("embed_hlsl_header") {
  assert(defined(invoker.input), "must set 'input'")
  assert(defined(invoker.output), "must set 'output'")

  action(target_name) {
    script = "${invoker.dawn_dxc_dir}/utils/embed_header.py"
    sources = [ invoker.input ]
    outputs = [ invoker.output ]
    args = [
      rebase_path(invoker.input, root_build_dir),
      rebase_path(invoker.output, root_build_dir),
    ]

    metadata = {
      # generate_embedded_hlsl_headers needs this mapping as an argument
      entries = [ "--entry " + rebase_path(invoker.input, root_build_dir) +
                  "=" + rebase_path(invoker.output, root_build_dir) ]
    }
  }
}
