#include <metal_stdlib>
using namespace metal;

uint tint_mod_u32(uint lhs, uint rhs) {
  uint const v = select(rhs, 1u, (rhs == 0u));
  return (lhs - ((lhs / v) * v));
}

[[max_total_threads_per_threadgroup(1)]]
kernel void f() {
  uint const a = 1u;
  uint const b = 0u;
  uint const r = tint_mod_u32(a, b);
}
