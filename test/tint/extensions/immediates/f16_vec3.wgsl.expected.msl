#include <metal_stdlib>
using namespace metal;

struct tint_module_vars_struct {
  const constant packed_half3* value;
  device packed_float3* output;
};

[[max_total_threads_per_threadgroup(1)]]
kernel void v(const constant packed_half3* value [[buffer(30)]], device packed_float3* output [[buffer(0)]]) {
  tint_module_vars_struct const tint_module_vars = tint_module_vars_struct{.value=value, .output=output};
  (*tint_module_vars.output) = packed_float3(float3(half3((*tint_module_vars.value))));
}
