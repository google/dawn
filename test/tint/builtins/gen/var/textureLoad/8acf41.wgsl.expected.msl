  float const v_4 = tint_ApplyHLGSingleChannel(v.x, params);
  float const v_5 = tint_ApplyHLGSingleChannel(v.y, params);
  return float3(v_4, v_5, tint_ApplyHLGSingleChannel(v.z, params));
}

float3 tint_ApplyPQTransferFunction(float3 v, tint_TransferFunctionParams params) {
  float3 const v_6 = float3(params.C);
  float3 const v_7 = float3(params.D);
  float3 const v_8 = float3(params.E);
  float3 const v_9 = float3(params.A);
  float3 const v_10 = powr(clamp(v, float3(0.0f), float3(1.0f)), (float3(1.0f) / float3(params.B)));
  return powr((max((v_10 - v_6), float3(0.0f)) / (v_7 - (v_8 * v_10))), (float3(1.0f) / v_9));
}

float3 tint_ApplySrcTransferFunction(float3 v, tint_TransferFunctionParams params) {
  if ((params.mode == 0u)) {
    return tint_ApplyGammaTransferFunction(v, params);
  } else {
    if ((params.mode == 1u)) {
